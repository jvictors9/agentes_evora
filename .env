# ---- Telegram (token do BotFather) ----
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Token aleatório que você cria; o MESMO valor vai no setWebhook
TELEGRAM_SECRET_TOKEN=troque-por-um-valor-aleatorio-longo

# ---- Manus ----
MANUS_API_KEY=coloque-sua-chave-do-manus
MANUS_BASE_URL=https://api.manus.ai/v2
MANUS_AGENT_PROFILE=manus-1.6-lite
# URL pública COMPLETA do endpoint /manus/webhook (precisa bater com a assinatura)
PUBLIC_MANUS_WEBHOOK_URL=https://seu-app.onrender.com/manus/webhook

# ---- Acesso (opcional) ----
ALLOWED_CHAT_IDS=
